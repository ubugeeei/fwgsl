{
  "name": "fwgsl",
  "displayName": "fwgsl — Functional WGSL",
  "description": "Language support for fwgsl, a pure functional language for WebGPU that compiles to WGSL.",
  "version": "0.1.0",
  "publisher": "fwgsl",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:fwgsl"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fwgsl",
        "aliases": [
          "fwgsl",
          "Functional WGSL"
        ],
        "extensions": [
          ".fwgsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fwgsl",
        "scopeName": "source.fwgsl",
        "path": "./syntaxes/fwgsl.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "fwgsl",
      "properties": {
        "fwgsl.server.path": {
          "type": "string",
          "default": "fwgsl-lsp",
          "description": "Path to the fwgsl language server executable."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  }
}
