{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "fwgsl",
  "scopeName": "source.fwgsl",
  "patterns": [
    { "include": "#comment-line" },
    { "include": "#comment-block" },
    { "include": "#string" },
    { "include": "#char" },
    { "include": "#number" },
    { "include": "#attribute" },
    { "include": "#keyword-control" },
    { "include": "#keyword-storage" },
    { "include": "#keyword" },
    { "include": "#operator" },
    { "include": "#function-definition" },
    { "include": "#type-constructor" }
  ],
  "repository": {
    "comment-line": {
      "name": "comment.line.double-dash.fwgsl",
      "match": "--.*$"
    },
    "comment-block": {
      "name": "comment.block.fwgsl",
      "begin": "\\{-",
      "end": "-\\}"
    },
    "string": {
      "name": "string.quoted.double.fwgsl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.fwgsl",
          "match": "\\\\(?:[\"\\\\nrt0abfv]|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\})"
        }
      ]
    },
    "char": {
      "name": "string.quoted.single.fwgsl",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.fwgsl",
          "match": "\\\\(?:['\\\\nrt0abfv]|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]+\\})"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.fwgsl",
          "match": "\\b0[xX][0-9a-fA-F_]+[ui]?\\b"
        },
        {
          "name": "constant.numeric.octal.fwgsl",
          "match": "\\b0[oO][0-7_]+[ui]?\\b"
        },
        {
          "name": "constant.numeric.binary.fwgsl",
          "match": "\\b0[bB][01_]+[ui]?\\b"
        },
        {
          "name": "constant.numeric.float.fwgsl",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9_]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.fwgsl",
          "match": "\\b[0-9][0-9_]*[ui]?\\b"
        }
      ]
    },
    "attribute": {
      "name": "entity.other.attribute-name.fwgsl",
      "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "keyword-control": {
      "name": "keyword.control.fwgsl",
      "match": "\\b(if|then|else|case|of|match|loop)\\b"
    },
    "keyword-storage": {
      "name": "keyword.storage.fwgsl",
      "match": "\\b(let|const|data|alias|extern|resource)\\b"
    },
    "keyword": {
      "name": "keyword.other.fwgsl",
      "match": "\\b(data|alias|extern|resource|trait|impl|let|in|case|of|if|then|else|where|bitfield|const|loop|do|forall|match|module|import|when|cfg|as|private|deriving)\\b"
    },
    "operator": {
      "name": "keyword.operator.fwgsl",
      "match": "\\|>|<-|->|=>|/=|<=|>=|&&|\\|\\||::|==|[+\\-*/%=<>|\\\\$]"
    },
    "function-definition": {
      "match": "^([a-z_][a-zA-Z0-9_']*)\\s+(?=[^:=\\n].*=)",
      "captures": {
        "1": { "name": "entity.name.function.fwgsl" }
      }
    },
    "type-constructor": {
      "name": "entity.name.type.fwgsl",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    }
  }
}
