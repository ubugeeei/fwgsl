-- Tensor-first surface syntax and short aliases.
-- This file is intended for `shadml check`.

data Samples = Samples (Tensor 8 F32)
data SamplesShort = SamplesShort (Ten 8 F32)

data Velocity = Velocity (Vector 3 F32)
data VelocityShort = VelocityShort (Vec 3 F32)

data Transform = Transform (Matrix 4 4 F32)
data TransformShort = TransformShort (Mat 4 4 F32)

data Weight = Weight (Scalar F32)
data WeightShort = WeightShort (Sca F32)
